@using Microsoft.AspNetCore.Identity
@using WebApplication1.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService

@{
    ApplicationUser currentUser = null;

    bool isAuthenticated = SignInManager.IsSignedIn(User);

    if (isAuthenticated)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    bool canCreateProduct = false;
    bool canViewProducts = false;
    bool canViewCart = false;

    if (isAuthenticated)
    {
        canCreateProduct = (await AuthorizationService.AuthorizeAsync(User, null, "Create Product")).Succeeded;
        canViewProducts = (await AuthorizationService.AuthorizeAsync(User, null, "View Products")).Succeeded;
        canViewCart = (await AuthorizationService.AuthorizeAsync(User, null, "View Cart")).Succeeded;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                display: flex;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                min-height: 100vh;
                background: #f8f9fa;
                border-right: 1px solid #ddd;
                padding: 10px;
            }

                .sidebar h5 {
                    cursor: pointer;
                    padding: 10px;
                    margin: 0;
                    background: #e9ecef;
                    border-radius: 6px;
                }

            .submenu {
                display: none;
                padding-left: 15px;
                margin-top: 5px;
            }

                .submenu a {
                    display: block;
                    padding: 6px;
                    text-decoration: none;
                    color: #333;
                    border-radius: 4px;
                }

                    .submenu a:hover {
                        background: #ddd;
                    }

            /* MAIN AREA */
            .main-content {
                flex: 1;
                padding: 20px;
            }

            /* TOP BAR */
            .topbar {
                width: 100%;
                background: #ffffff;
                border-bottom: 1px solid #ddd;
                padding: 10px 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .brand {
                font-weight: bold;
                font-size: 18px;
            }

            .auth-buttons a {
                margin-left: 8px;
            }
    </style>
</head>

<body>

    @if (isAuthenticated)
    {
        <!-- SIDEBAR -->
        <div class="sidebar">

            <!-- PRODUCTS -->
            <h5 onclick="toggleMenu('productsMenu')">📦 Products</h5>
            <div id="productsMenu" class="submenu">

                @if (canViewProducts)
                {
                    <a asp-controller="Product" asp-action="Index">All Products</a>
                }

                @if (canCreateProduct)
                {
                    <a asp-controller="Product" asp-action="Create">Create Product</a>
                }

            </div>

            <!-- CART -->
            <h5 onclick="toggleMenu('cartMenu')">🛒 Cart</h5>
            <div id="cartMenu" class="submenu">

                @if (canViewCart)
                {
                    <a asp-controller="Cart" asp-action="MyCart">View Cart</a>
                }

            </div>

        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- TOP NAVBAR -->
        <div class="topbar">

            <div class="brand">
                WebApplication1
            </div>

            <div class="d-flex align-items-center">

                @if (isAuthenticated)
                {
                    <span class="badge bg-primary me-2 px-3 py-2">
                        @currentUser?.UserName
                    </span>

                    <a asp-controller="Auth"
                           asp-action="Logout"
                           class="btn btn-outline-danger btn-sm">
                        Logout
                    </a>
                }
                else
                {
                    <a asp-controller="Auth"
                           asp-action="Login"
                           class="btn btn-outline-primary btn-sm me-2">
                        Login
                    </a>

                    <a asp-controller="Auth"
                           asp-action="Register"
                           class="btn btn-primary btn-sm">
                        Register
                    </a>
                }

            </div>

        </div>

        @RenderBody()

    </div>

    <script>
            function toggleMenu(id) {
                const menu = document.getElementById(id);

                if (menu.style.display === "block") {
                    menu.style.display = "none";
                } else {
                    menu.style.display = "block";
                }
            }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>