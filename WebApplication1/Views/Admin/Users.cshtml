@model IEnumerable<ProjectData.Models.ApplicationUser>

<h2>Users</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>UserName</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <a asp-action="EditUserRoles"
                           asp-route-userId="@user.Id"
                           class="btn btn-warning btn-sm">
                        Assign Roles
                    </a>

                    <a asp-action="DeleteUser"
                           asp-route-userId="@user.Id"
                           class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>